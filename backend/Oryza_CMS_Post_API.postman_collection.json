{
  "info": {
    "_postman_id": "oryza-cms-post-api",
    "name": "Oryza CMS - Post API Testing",
    "description": "Complete testing collection untuk Post endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. GET ALL POSTS (PUBLIC)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/posts?page=1&limit=10&status=PUBLISHED",
          "host": ["{{base_url}}"],
          "path": ["posts"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "status",
              "value": "PUBLISHED"
            }
          ]
        },
        "description": "Ambil semua posts dengan pagination dan filter status. PUBLIC endpoint - tidak butuh token."
      }
    },
    {
      "name": "2. CREATE POST (PROTECTED)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Intro to Node.js\",\n  \"content\": \"Node.js adalah runtime JavaScript yang berjalan di server. Dengan Node.js, Anda bisa membuat aplikasi backend dengan JavaScript.\",\n  \"tags\": \"nodejs, javascript, backend\",\n  \"categoryId\": \"{{category_id}}\",\n  \"thumbnail\": \"/uploads/nodejs.jpg\",\n  \"metaTitle\": \"Learn Node.js Basics\",\n  \"metaDescription\": \"Tutorial lengkap Node.js untuk pemula\",\n  \"status\": \"DRAFT\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/post/create",
          "host": ["{{base_url}}"],
          "path": ["post", "create"]
        },
        "description": "Buat post baru. PROTECTED - butuh token ADMIN atau SUPER_ADMIN. Copy post ID dari response untuk test lainnya."
      }
    },
    {
      "name": "3. GET POST BY ID (PUBLIC)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/post/{{post_id}}",
          "host": ["{{base_url}}"],
          "path": ["post", "{{post_id}}"]
        },
        "description": "Ambil detail post berdasarkan ID. PUBLIC endpoint. Views otomatis increment +1."
      }
    },
    {
      "name": "4. GET POST BY SLUG (PUBLIC)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/post/slug/intro-to-nodejs",
          "host": ["{{base_url}}"],
          "path": ["post", "slug", "intro-to-nodejs"]
        },
        "description": "Ambil post berdasarkan slug (URL-friendly). PUBLIC endpoint. Ganti 'intro-to-nodejs' dengan slug post Anda."
      }
    },
    {
      "name": "5. GET POSTS BY CATEGORY (PUBLIC)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/posts/category/{{category_id}}?page=1&limit=10",
          "host": ["{{base_url}}"],
          "path": ["posts", "category", "{{category_id}}"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        },
        "description": "Ambil posts berdasarkan category. PUBLIC endpoint. Filter hanya PUBLISHED posts."
      }
    },
    {
      "name": "6. SEARCH POSTS (PUBLIC)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/posts/search/nodejs?page=1&limit=10",
          "host": ["{{base_url}}"],
          "path": ["posts", "search", "nodejs"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        },
        "description": "Cari posts berdasarkan keyword. PUBLIC endpoint. Search di title, content, dan tags. Case insensitive."
      }
    },
    {
      "name": "7. UPDATE POST (PROTECTED)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Node.js Complete Guide\",\n  \"tags\": \"nodejs, javascript, tutorial\",\n  \"status\": \"PUBLISHED\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/post/update/{{post_id}}",
          "host": ["{{base_url}}"],
          "path": ["post", "update", "{{post_id}}"]
        },
        "description": "Update post. PROTECTED - butuh token ADMIN+. Slug otomatis update jika title berubah. Hanya kirim field yang mau diubah."
      }
    },
    {
      "name": "8. DELETE POST (PROTECTED)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/post/delete/{{post_id}}",
          "host": ["{{base_url}}"],
          "path": ["post", "delete", "{{post_id}}"]
        },
        "description": "Hapus post. PROTECTED - butuh token ADMIN+. Permanent delete - tidak bisa di-recover."
      }
    },
    {
      "name": "9. CREATE POST 2 (For Testing)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Express.js Fundamentals\",\n  \"content\": \"Express.js adalah framework web paling populer untuk Node.js. Express menyediakan fitur routing, middleware, dan banyak lagi.\",\n  \"tags\": \"express, nodejs, framework, backend\",\n  \"categoryId\": \"{{category_id}}\",\n  \"status\": \"PUBLISHED\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/post/create",
          "host": ["{{base_url}}"],
          "path": ["post", "create"]
        },
        "description": "Buat post ke-2 untuk testing search, filter, dll."
      }
    },
    {
      "name": "10. CREATE POST 3 (For Testing)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Database Design Best Practices\",\n  \"content\": \"Desain database yang baik adalah fondasi aplikasi yang kuat. Dalam tutorial ini, kita akan membahas normalisasi, indexing, dan query optimization.\",\n  \"tags\": \"database, sql, design, best-practices\",\n  \"categoryId\": \"{{category_id}}\",\n  \"status\": \"PUBLISHED\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/post/create",
          "host": ["{{base_url}}"],
          "path": ["post", "create"]
        },
        "description": "Buat post ke-3 dengan tags berbeda untuk test search."
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "category_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "post_id",
      "value": "",
      "type": "string"
    }
  ]
}
